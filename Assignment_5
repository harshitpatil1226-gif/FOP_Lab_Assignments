//Program to calculate factorial of a number with and without recurssion
#include <stdio.h>
// Function to calculate factorial using recursion
unsigned long long factorial_recursive(int n) {
    if (n == 0 || n == 1) {
        return 1;
    }
    return n * factorial_recursive(n - 1);
}
// Function to calculate factorial using iteration
unsigned long long factorial_iterative(int n) {
    unsigned long long result = 1;
    for (int i = 2; i <= n; i++) {
        result *= i;
    }
    return result;
}
int main() {
    int number;
    printf("Enter a positive integer: ");
    scanf("%d", &number);

    if (number < 0) {
        printf("Error: Factorial is not defined for negative numbers.\n");
        return 1;
    }

    unsigned long long result_recursive = factorial_recursive(number);
    unsigned long long result_iterative = factorial_iterative(number);

    printf("Factorial of %d (recursive): %llu\n", number, result_recursive);
    printf("Factorial of %d (iterative): %llu\n", number, result_iterative);

    return 0;
}
